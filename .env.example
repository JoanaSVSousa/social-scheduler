SECRET_KEY=replace-with-a-long-random-secret
CREDENTIALS_ENCRYPTION_KEY=generate-with-python-scripts-generate-encryption-key-py
ADMIN_USERNAME=SquaredRedes
ADMIN_PASSWORD=replace-with-a-strong-password
FLASK_DEBUG=0

# Public app URL used by cron jobs to wake/check the Render web service.
APP_BASE_URL=https://your-render-service.onrender.com

# Email reports
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=your@email.com
REPORT_TO_EMAIL=team@email.com
REPORT_EMAIL_SUBJECT=Content Automation Platform report

# Supabase/Postgres production database. Leave unset for local SQLite.
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require

# Supabase Storage public media uploads.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_MEDIA_BUCKET=social-media

# Optional override if the host provides ffmpeg outside imageio-ffmpeg.
FFMPEG_BINARY=/usr/bin/ffmpeg
